{
    "name": "laravel-ddd/starter",
    "description": "DDD Starter Kit for Laravel 13/12",
    "type": "laravel-package",
    "license": "MIT",
    "require": {
        "php": "^8.4",
        "laravel/framework": "^12.0|^13.0"
    },
    "require-dev": {
        "php": "^8.2"
    },
    "autoload": {
        "psr-4": {
            "LaravelDdd\\Starter\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "LaravelDdd\\Starter\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "LaravelDdd\\Starter\\Providers\\DddServiceProvider"
            ]
        }
    },
    "config": {
        "sort-packages": true
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}